CREATE DATABASE IF NOT EXISTS manufacturing_simple;

USE manufacturing_simple;

CREATE TABLE plants
(
    plant_id UInt32,
    plant_name String,
    city String,
    country String,
    is_active UInt8
)
ENGINE = MergeTree()
ORDER BY plant_id;

CREATE TABLE products
(
    product_id UInt32,
    product_name String,
    product_type String,
    unit_price Float64,
    is_active UInt8
)
ENGINE = MergeTree()
ORDER BY product_id;

CREATE TABLE inventory
(
    inventory_id UInt32,
    plant_id UInt32,
    product_id UInt32,
    quantity_on_hand Float64,
    snapshot_date Date
)
ENGINE = MergeTree()
ORDER BY inventory_id;

CREATE TABLE production
(
    production_id UInt32,
    plant_id UInt32,
    product_id UInt32,
    produced_qty Float64,
    production_date Date
)
ENGINE = MergeTree()
ORDER BY production_id;

CREATE TABLE shipments
(
    shipment_id UInt32,
    plant_id UInt32,
    product_id UInt32,
    shipped_qty Float64,
    shipment_date Date
)
ENGINE = MergeTree()
ORDER BY shipment_id;




